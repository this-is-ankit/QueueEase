# ============================================
# QueueEase Backend - Environment Variables
# ============================================
# Copy this file to .env and populate the real values
# before starting the application.
5
# -----------------------------
# System Config
# -----------------------------
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# -----------------------------
# Database setup (PostgreSQL)
# -----------------------------
# Required by Prisma ORM
DATABASE_URL="postgresql://user:password@localhost:5432/queueease?schema=public"

# -----------------------------
# Security
# -----------------------------
# JWT secret for signing tokens (minimum 64 chars recommended)
JWT_SECRET="queueease_super_secret_jwt_key_minimum_64_chars_change_in_production_2024"

# -----------------------------
# Cloudinary Integrations
# -----------------------------
# Required for uploading Clinic/Doctor images and Verification spatial proofs
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# -----------------------------
# Razorpay Integrations
# -----------------------------
# Required for capturing upfront Appointment Payments
RAZORPAY_KEY_ID="rzp_test_your_key_here"
RAZORPAY_KEY_SECRET="your_razorpay_secret"

# -----------------------------
# Firebase Integrations
# -----------------------------
# Stringified JSON file contents of your Firebase Service Account
# Required for FCM Push Notifications. Example format: {"type":"service_account","project_id":"queueease"...}
FIREBASE_SERVICE_ACCOUNT=""
# -----------------------------
# Geographic Searching API (Optional)
# -----------------------------
# Used on mobile frontends, but configured here for parity
GOOGLE_MAPS_API_KEY="your_google_maps_api_key"
